{{ >partials/header}}


{{#banner}}
<section class="banner" style="background-image: url('images/{{background}}')">
    {{title}}
</section>


<h2>{{title}} disponíveis para adoção</h2>
{{/banner}}

<div class="container list">
    {{#list}}
    <div class="item">
        <img src="images/{{ image }}" class="item--image" />
        <div class="item--name">{{ name }}</div>
        <div class="item--color">Cor: {{ color }}</div>
        <div class="item--genre">Gênero: {{ sex }}</div>
    </div>
    {{/list}}
</div>

{{^list}}
<div class="container no-list">
    <h3>Opss... Não encontramos nenhum pet com esse nome!</h3>
</div>
{{/list}}

{{ >partials/footer}}
